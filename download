import React, { useState, useEffect, useRef } from 'react';
import { UserProfile, Workout } from '../../types';
import { collection, addDoc, getDocs, orderBy, query, limit } from 'firebase/firestore';
import { db } from '../../lib/firebase';
import { motion, AnimatePresence } from 'motion/react';
import { Play, Square, Save, History, Dumbbell, Activity, Timer } from 'lucide-react';
import { cn } from '../../lib/utils';

interface TracksProps {
  profile: UserProfile | null;
}

const WORKOUT_TYPES = [
  { id: 'weightlifting', label: 'Weightlifting', met: 6.0 },
  { id: 'crossfit', label: 'CrossFit', met: 10.0 },
  { id: 'cardio', label: 'Cardio / Running', met: 9.0 },
  { id: 'hiit', label: 'HIIT', met: 12.0 },
  { id: 'cycling', label: 'Cycling', met: 8.0 },
  { id: 'swimming', label: 'Swimming', met: 8.0 },
  { id: 'yoga', label: 'Yoga / Mobility', met: 2.5 },
  { id: 'sports', label: 'Sports / MMA', met: 7.0 },
];

const MUSCLE_GROUPS = [
  'Full Body', 'Chest', 'Back', 'Shoulders', 'Arms', 'Legs', 'Core', 'Cardio Only'
];

export const Tracks: React.FC<TracksProps> = ({ profile }) => {
  const [isTimerRunning, setIsTimerRunning] = useState(false);
  const [elapsedSeconds, setElapsedSeconds] = useState(0);
  const [workoutType, setWorkoutType] = useState('weightlifting');
  const [muscleGroup, setMuscleGroup] = useState('Full Body');
  const [volume, setVolume] = useState('');
  const [history, setHistory] = useState<Workout[]>([]);
  const [saving, setSaving] = useState(false);
  
  const timerRef = useRef<NodeJS.Timeout | null>(null);

  useEffect(() => {
    if (isTimerRunning) {
      const start = Date.now() - elapsedSeconds * 1000;
      timerRef.current = setInterval(() => {
        setElapsedSeconds(Math.floor((Date.now() - start) / 1000));
      }, 1000);
    } else {
      if (timerRef.current) clearInterval(timerRef.current);
    }
    return () => { if (timerRef.current) clearInterval(timerRef.current); };
  }, [isTimerRunning]);

  useEffect(() => {
    fetchHistory();
  }, [profile]);

  const fetchHistory = async () => {
    if (!profile) return;
    const q = query(collection(db, 'users', profile.uid, 'workouts'), orderBy('ts', 'desc'), limit(10));
    const snap = await getDocs(q);
    setHistory(snap.docs.map(d => ({ id: d.id, ...d.data() } as Workout)));
  };

  const formatTime = (totalSeconds: number) => {
    const h = Math.floor(totalSeconds / 3600);
    const m = Math.floor((totalSeconds % 3600) / 60);
    const s = totalSeconds % 60;
    return `${String(h).padStart(2, '0')}:${String(m).padStart(2, '0')}:${String(s).padStart(2, '0')}`;
  };

  const calculateCalories = (seconds: number) => {
    const met = WORKOUT_TYPES.find(t => t.id === workoutType)?.met || 5;
    const weight = profile?.weight || 75;
    return Math.round((met * weight * (seconds / 3600)));
  };

  const handleSave = async () => {
    if (!profile || elapsedSeconds < 60) return; // Min 1 min
    setSaving(true);
    try {
      const now = new Date();
      const calories = calculateCalories(elapsedSeconds);
      const workoutData = {
        athleteUid: profile.uid,
        date: now.toISOString().split('T')[0],
        dateLabel: now.toLocaleDateString('en-US', { month: 'short', day: 'numeric' }),
        type: WORKOUT_TYPES.find(t => t.id === workoutType)?.label || workoutType,
        muscle: muscleGroup,
        volume: parseInt(volume) || 0,
        calories,
        duration: elapsedSeconds,
        ts: Date.now()
      };

      await addDoc(collection(db, 'users', profile.uid, 'workouts'), workoutData);
      
      setElapsedSeconds(0);
      setIsTimerRunning(false);
      setVolume('');
      await fetchHistory();
    } catch (err) {
      console.error(err);
    } finally {
      setSaving(false);
    }
  };

  return (
    <div className="space-y-10 pb-20">
      <div className="flex flex-col md:flex-row justify-between items-start md:items-end gap-4">
        <div>
          <h1 className="font-display text-4xl tracking-tight uppercase">TRACKS</h1>
          <p className="font-mono text-[10px] tracking-[0.3em] text-zinc-500 uppercase mt-1">Operational Protocol Execution</p>
        </div>
      </div>

      <div className="grid grid-cols-1 lg:grid-cols-3 gap-8">
        {/* Timer Box */}
        <div className="lg:col-span-2 space-y-6">
          <div className="bg-zinc-950 border border-white/10 p-10 flex flex-col items-center justify-center relative overflow-hidden group">
            <div className="absolute inset-0 bg-accent/5 opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none" />
            
            <div className={cn(
              "font-display text-6xl md:text-8xl tracking-tighter mb-8 tabular-nums transition-all",
              isTimerRunning ? "text-white animate-pulse-glow" : "text-zinc-700"
            )}>
              {formatTime(elapsedSeconds)}
            </div>

            <div className="flex gap-4">
              <button
                onClick={() => setIsTimerRunning(!isTimerRunning)}
                className={cn(
                  "flex items-center gap-3 px-8 py-4 font-display text-xs tracking-widest uppercase transition-all scale-100 active:scale-95",
                  isTimerRunning 
                    ? "bg-red-500/20 text-red-500 border border-red-500/30 hover:bg-red-500/30" 
                    : "bg-accent text-black hover:bg-white"
                )}
              >
                {isTimerRunning ? <Square size={16} /> : <Play size={16} />}
                {isTimerRunning ? 'Stop Sector' : 'Start Sector'}
              </button>
              
              {elapsedSeconds > 0 && !isTimerRunning && (
                <button
                  onClick={() => setElapsedSeconds(0)}
                  className="px-8 py-4 border border-white/10 text-zinc-500 hover:text-white hover:border-white/20 font-display text-xs tracking-widest uppercase transition-all"
                >
                  Reset
                </button>
              )}
            </div>

            {elapsedSeconds > 0 && (
              <div className="mt-8 flex gap-8">
                <div className="text-center">
                  <div className="text-zinc-500 font-mono text-[9px] uppercase tracking-widest mb-1">Energy Burn</div>
                  <div className="text-orange-500 font-display text-xl">{calculateCalories(elapsedSeconds)} <span className="text-[10px]">kcal</span></div>
                </div>
                <div className="text-center opacity-40">
                  <div className="text-zinc-500 font-mono text-[9px] uppercase tracking-widest mb-1">Target Zone</div>
                  <div className="text-white font-display text-xl">85%</div>
                </div>
              </div>
            )}
          </div>

          <div className="bg-white/5 border border-white/10 p-8 space-y-8">
            <h3 className="font-mono text-[11px] uppercase tracking-[0.3em] text-accent/70 flex items-center gap-3">
              <Save size={14} /> Mission Configuration
            </h3>

            <div className="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div className="space-y-2">
                <label className="font-mono text-[9px] uppercase tracking-widest text-zinc-500 ml-1">Workout Type</label>
                <select 
                  value={workoutType}
                  onChange={(e) => setWorkoutType(e.target.value)}
                  className="w-full bg-black border border-white/5 focus:border-accent/40 outline-none px-4 py-3 font-sans text-sm"
                >
                  {WORKOUT_TYPES.map(t => <option key={t.id} value={t.id}>{t.label}</option>)}
                </select>
              </div>
              <div className="space-y-2">
                <label className="font-mono text-[9px] uppercase tracking-widest text-zinc-500 ml-1">Target Muscle Group</label>
                <select 
                  value={muscleGroup}
                  onChange={(e) => setMuscleGroup(e.target.value)}
                  className="w-full bg-black border border-white/5 focus:border-accent/40 outline-none px-4 py-3 font-sans text-sm"
                >
                  {MUSCLE_GROUPS.map(g => <option key={g} value={g}>{g}</option>)}
                </select>
              </div>
            </div>

            <div className="space-y-2">
              <label className="font-mono text-[9px] uppercase tracking-widest text-zinc-500 ml-1">Total Payload (Accumulated Weight in KG)</label>
              <input 
                type="number"
                value={volume}
                onChange={(e) => setVolume(e.target.value)}
                placeholder="e.g. 5200"
                className="w-full bg-black border border-white/5 focus:border-accent/40 outline-none px-4 py-3 font-sans text-sm"
              />
            </div>

            <button
              onClick={handleSave}
              disabled={saving || elapsedSeconds < 60}
              className="w-full py-4 bg-accent/10 border border-accent/20 text-accent font-display text-[11px] font-bold tracking-[0.3em] uppercase hover:bg-accent hover:text-black transition-all disabled:opacity-30 disabled:cursor-not-allowed group relative overflow-hidden"
            >
              <span className="relative z-10">{saving ? 'Transmitting Data...' : 'Commit to Palace Archive'}</span>
            </button>
          </div>
        </div>

        {/* History Column */}
        <div className="space-y-6">
          <div className="flex items-center gap-3">
            <History size={16} className="text-zinc-500" />
            <h2 className="font-mono text-[10px] uppercase tracking-[0.4em] text-zinc-500">Sector Logs</h2>
          </div>

          <div className="space-y-3">
            {history.map((w, i) => (
              <motion.div 
                key={w.id}
                initial={{ opacity: 0, x: 20 }}
                animate={{ opacity: 1, x: 0 }}
                transition={{ delay: i * 0.05 }}
                className="p-4 bg-white/5 border border-white/5 rounded-sm"
              >
                <div className="flex justify-between items-start mb-2">
                  <span className="font-mono text-[10px] uppercase tracking-widest text-white/40">{w.dateLabel}</span>
                  <div className="w-1.5 h-1.5 rounded-full bg-accent/40" />
                </div>
                <div className="font-mono text-xs uppercase tracking-tight mb-2">{w.type}</div>
                <div className="flex justify-between items-baseline">
                   <div className="font-display text-xl">{w.volume ? w.volume + 'kg' : formatTime(w.duration).slice(0,5)}</div>
                   <div className="font-mono text-[9px] uppercase tracking-widest text-zinc-600">{w.calories} kcal</div>
                </div>
              </motion.div>
            ))}
          </div>
        </div>
      </div>
    </div>
  );
};
