import React, { useEffect, useRef, useState } from 'react';
import { ANATOMY_SEGMENTS, BONES } from '../../constants/anatomy';
import { cn } from '../../lib/utils';

interface AnatomyModelProps {
  selectedPart?: string | null;
  onSelect?: (part: string) => void;
  autoRotate?: boolean;
  intensityMap?: Record<string, number>;
  className?: string;
}

const COLORS = {
  accent: '#00f2ff',
  common: 'rgba(255, 255, 255, 0.18)',
  rare: 'rgba(139, 92, 246, 0.75)',
  serious: 'rgba(239, 68, 68, 0.75)',
  wire: 'rgba(255, 255, 255, 0.05)',
  selected: '#FFFFFF',
};

export const AnatomyModel: React.FC<AnatomyModelProps> = ({
  selectedPart,
  onSelect,
  autoRotate = true,
  intensityMap = {},
  className,
}) => {
  const canvasRef = useRef<HTMLCanvasElement>(null);
  const containerRef = useRef<HTMLDivElement>(null);
  const rotationRef = useRef({ x: -0.06, y: 0.3 });
  const isDraggingRef = useRef(false);
  const lastPosRef = useRef({ x: 0, y: 0 });
  const [dimensions, setDimensions] = useState({ width: 0, height: 0 });

  useEffect(() => {
    if (!containerRef.current) return;
    const observer = new ResizeObserver((entries) => {
      const { width, height } = entries[0].contentRect;
      setDimensions({ width, height });
    });
    observer.observe(containerRef.current);
    return () => observer.disconnect();
  }, []);

  useEffect(() => {
    const canvas = canvasRef.current;
    if (!canvas || dimensions.width <= 0 || dimensions.height <= 0) return;

    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    let frameId: number;
    let frameCount = 0;

    const project = (x: number, y: number, z: number) => {
      const { x: rotX, y: rotY } = rotationRef.current;
      const cosY = Math.cos(rotY), sinY = Math.sin(rotY);
      const cosX = Math.cos(rotX), sinX = Math.sin(rotX);
      
      const rx = x * cosY - z * sinY;
      const rz = x * sinY + z * cosY;
      const ry = y * cosX - rz * sinX;
      const rz2 = y * sinX + rz * cosX;
      
      const fov = 600;
      const denom = fov + rz2 + 200;
      const s = denom === 0 ? 0 : fov / denom;
      
      const px = dimensions.width / 2 + rx * s;
      const py = dimensions.height / 2 + ry * s;

      return {
        x: isFinite(px) ? px : 0,
        y: isFinite(py) ? py : 0,
        z: rz2,
        s: isFinite(s) ? s : 0
      };
    };

    const render = () => {
      if (autoRotate && !isDraggingRef.current) {
        rotationRef.current.y += 0.008;
      }

      ctx.clearRect(0, 0, dimensions.width, dimensions.height);
      
      // Draw grid floor (subtle)
      ctx.strokeStyle = 'rgba(255, 255, 255, 0.015)';
      ctx.lineWidth = 1;
      for (let x = 0; x < dimensions.width; x += 20) {
        ctx.beginPath(); ctx.moveTo(x, 0); ctx.lineTo(x, dimensions.height); ctx.stroke();
      }
      for (let y = 0; y < dimensions.height; y += 20) {
        ctx.beginPath(); ctx.moveTo(0, y); ctx.lineTo(dimensions.width, y); ctx.stroke();
      }

      // Draw scanner scanline
      const scanY = (frameCount * 2) % dimensions.height;
      ctx.beginPath();
      ctx.strokeStyle = 'rgba(0, 242, 255, 0.15)';
      ctx.lineWidth = 1;
      ctx.moveTo(0, scanY);
      ctx.lineTo(dimensions.width, scanY);
      ctx.stroke();

      // Draw bones (enhanced with depth-based opacity)
      ctx.lineWidth = 0.8;
      BONES.forEach(([a, b]) => {
        const pa = project(a.cx, a.cy, a.cz);
        const pb = project(b.cx, b.cy, b.cz);
        const avgZ = (pa.z + pb.z) / 2;
        const opacity = Math.max(0.05, Math.min(0.2, (avgZ + 300) / 600));
        ctx.strokeStyle = `rgba(255, 255, 255, ${opacity})`;
        ctx.beginPath(); ctx.moveTo(pa.x, pa.y); ctx.lineTo(pb.x, pb.y); ctx.stroke();
      });

      // Sort segments by depth
      const sorted = ANATOMY_SEGMENTS.map(seg => ({
        seg,
        proj: project(seg.cx, seg.cy, seg.cz)
      })).sort((a, b) => a.proj.z - b.proj.z);

      sorted.forEach(({ seg, proj }) => {
        const isSelected = selectedPart === seg.part;
        const intensity = intensityMap[seg.part] || 0;
        
        let color = isSelected ? COLORS.selected : (seg.ct === 's' ? COLORS.serious : seg.ct === 'r' ? COLORS.rare : COLORS.common);
        if (intensity > 0) {
          const alpha = 0.4 + (intensity / 10) * 0.6;
          color = intensity >= 7 ? `rgba(239, 68, 68, ${alpha})` : intensity >= 4 ? `rgba(255, 183, 0, ${alpha})` : `rgba(0, 242, 255, ${alpha})`;
        }

        const rx = seg.w * proj.s * 1.1; // Slightly larger for better visibility
        const ry = seg.h * proj.s * 0.8;
        const depthAlpha = Math.max(0.3, Math.min(1, (proj.z + 300) / 500));

        ctx.save();
        if (isSelected) {
          ctx.shadowBlur = 15;
          ctx.shadowColor = COLORS.accent;
        }

        ctx.beginPath();
        if (seg.type === 'e') {
          ctx.ellipse(proj.x, proj.y, rx, ry, 0, 0, Math.PI * 2);
        } else {
          ctx.rect(proj.x - rx, proj.y - ry, rx * 2, ry * 2);
        }
        
        const m = color.match(/rgba?\((\d+), (\d+), (\d+)(?:, ([\d.]+))?\)/);
        const rgba = m ? [m[1], m[2], m[3], m[4] || 1] : [255, 255, 255, 0.2];
        const finalAlpha = Number(rgba[3]) * (isSelected ? 1 : depthAlpha * 0.8);
        
        // Gradient fill for depth/realism
        const gradient = ctx.createRadialGradient(proj.x, proj.y, 0, proj.x, proj.y, Math.max(rx, ry));
        gradient.addColorStop(0, `rgba(${rgba[0]}, ${rgba[1]}, ${rgba[2]}, ${finalAlpha})`);
        gradient.addColorStop(1, `rgba(${rgba[0]}, ${rgba[1]}, ${rgba[2]}, ${finalAlpha * 0.5})`);
        
        ctx.fillStyle = gradient;
        ctx.fill();
        
        if (isSelected) {
          ctx.strokeStyle = COLORS.accent;
          ctx.lineWidth = 2;
          ctx.stroke();
        } else {
          ctx.strokeStyle = `rgba(255,255,255,${finalAlpha * 0.1})`;
          ctx.lineWidth = 0.5;
          ctx.stroke();
        }
        ctx.restore();
      });

      frameCount++;
      frameId = requestAnimationFrame(render);
    };

    render();
    return () => cancelAnimationFrame(frameId);
  }, [dimensions, autoRotate, selectedPart, intensityMap]);

  const handlePointerDown = (e: React.PointerEvent) => {
    isDraggingRef.current = true;
    lastPosRef.current = { x: e.clientX, y: e.clientY };
    canvasRef.current?.setPointerCapture(e.pointerId);
  };

  const handlePointerMove = (e: React.PointerEvent) => {
    if (!isDraggingRef.current) return;
    const dx = e.clientX - lastPosRef.current.x;
    const dy = e.clientY - lastPosRef.current.y;
    rotationRef.current.y += dx * 0.01;
    rotationRef.current.x += dy * 0.01;
    lastPosRef.current = { x: e.clientX, y: e.clientY };
  };

  const handlePointerUp = (e: React.PointerEvent) => {
    isDraggingRef.current = false;
    canvasRef.current?.releasePointerCapture(e.pointerId);

    // Click selection logic
    const rect = canvasRef.current?.getBoundingClientRect();
    if (!rect) return;
    const x = e.clientX - rect.left;
    const y = e.clientY - rect.top;

    const project = (cx: number, cy: number, cz: number) => {
      const { x: rotX, y: rotY } = rotationRef.current;
      const cosY = Math.cos(rotY), sinY = Math.sin(rotY);
      const cosX = Math.cos(rotX), sinX = Math.sin(rotX);
      const rx = cx * cosY - cz * sinY;
      const rz = cx * sinY + cz * cosY;
      const ry = cy * cosX - rz * sinX;
      const rz2 = cy * sinX + rz * cosX;
      
      const fov = 600;
      const denom = fov + rz2 + 200;
      const s = denom === 0 ? 0 : fov / denom;
      
      const px = dimensions.width / 2 + rx * s;
      const py = dimensions.height / 2 + ry * s;

      return {
        x: isFinite(px) ? px : 0,
        y: isFinite(py) ? py : 0,
      };
    };

    let nearest = null;
    let minDist = 30;
    
    ANATOMY_SEGMENTS.forEach(seg => {
      const p = project(seg.cx, seg.cy, seg.cz);
      const d = Math.hypot(p.x - x, p.y - y);
      if (d < minDist) {
        minDist = d;
        nearest = seg;
      }
    });

    if (nearest && onSelect) {
      onSelect(nearest.part);
    }
  };

  return (
    <div ref={containerRef} className={cn("relative w-full h-full bg-black/40 border border-white/5 rounded-lg overflow-hidden group cursor-crosshair", className)}>
      <canvas
        ref={canvasRef}
        width={dimensions.width}
        height={dimensions.height}
        onPointerDown={handlePointerDown}
        onPointerMove={handlePointerMove}
        onPointerUp={handlePointerUp}
        className="touch-none w-full h-full"
      />
      <div className="absolute bottom-2 left-3 font-mono text-[10px] text-accent/50 uppercase tracking-widest pointer-events-none group-hover:text-accent transition-colors">
        Anatomical Engine v2.0
      </div>
      <div className="absolute top-2 right-3 font-mono text-[10px] text-white/20 uppercase tracking-widest pointer-events-none">
        {Math.round(rotationRef.current.y * 57.3)}°
      </div>
    </div>
  );
};
