import React, { useState, useEffect } from 'react';
import { UserProfile, PainLog } from '../../types';
import { collection, addDoc, getDocs, orderBy, query, limit, where } from 'firebase/firestore';
import { db } from '../../lib/firebase';
import { motion, AnimatePresence } from 'motion/react';
import { AnatomyModel } from '../visuals/AnatomyModel';
import { Dna, MapPin, AlertTriangle, History, Check } from 'lucide-react';
import { cn } from '../../lib/utils';

interface PalaceStateProps {
  profile: UserProfile | null;
}

export const PalaceState: React.FC<PalaceStateProps> = ({ profile }) => {
  const [selectedPart, setSelectedPart] = useState<string | null>(null);
  const [intensity, setIntensity] = useState(5);
  const [type, setType] = useState<'sharp' | 'dull'>('dull');
  const [todayLogs, setTodayLogs] = useState<PainLog[]>([]);
  const [saving, setSaving] = useState(false);

  useEffect(() => {
    fetchTodayLogs();
  }, [profile]);

  const fetchTodayLogs = async () => {
    if (!profile) return;
    const today = new Date().toISOString().split('T')[0];
    const q = query(
      collection(db, 'users', profile.uid, 'pain_logs'),
      where('date', '==', today),
      orderBy('ts', 'desc')
    );
    const snap = await getDocs(q);
    setTodayLogs(snap.docs.map(d => d.data() as PainLog));
  };

  const handleLog = async () => {
    if (!profile || !selectedPart) return;
    setSaving(true);
    try {
      const logData: PainLog = {
        ts: Date.now(),
        date: new Date().toISOString().split('T')[0],
        part: selectedPart,
        intensity,
        type
      };
      await addDoc(collection(db, 'users', profile.uid, 'pain_logs'), logData);
      await fetchTodayLogs();
      setSelectedPart(null);
    } catch (err) {
      console.error(err);
    } finally {
      setSaving(false);
    }
  };

  const intensityMap = todayLogs.reduce((acc, log) => {
    acc[log.part] = Math.max(acc[log.part] || 0, log.intensity);
    return acc;
  }, {} as Record<string, number>);

  return (
    <div className="space-y-10 pb-20">
      <div className="relative overflow-hidden p-10 border border-white/5 bg-gradient-to-br from-indigo-500/5 to-transparent rounded-sm">
        <div className="relative z-10">
          <div className="font-mono text-[10px] tracking-[0.4em] text-indigo-400 uppercase mb-2">Protocol: Morning Bio-Scan</div>
          <h1 className="font-display text-4xl tracking-tight uppercase">PALACE STATE</h1>
          <p className="font-mono text-[11px] uppercase tracking-[0.2em] text-zinc-500 mt-2 max-w-lg">
            Subjective spatial mapping. Log what the sensors miss. Patterns here trigger kinetic alerts in the legion.
          </p>
        </div>
        <div className="absolute right-[-2%] top-1/2 -translate-y-1/2 font-display text-8xl text-white/[0.01] pointer-events-none select-none uppercase tracking-[1em] whitespace-nowrap">
          STATE
        </div>
      </div>

      <div className="grid grid-cols-1 lg:grid-cols-12 gap-8">
        {/* Model Side */}
        <div className="lg:col-span-5 space-y-6">
          <div className="aspect-[3/4] w-full max-w-sm mx-auto overflow-hidden rounded-sm border border-white/5 bg-black/40 relative">
             <AnatomyModel 
               selectedPart={selectedPart}
               onSelect={setSelectedPart}
               intensityMap={intensityMap}
               className="w-full h-full border-none rounded-none bg-transparent"
             />
          </div>
          <div className="text-center italic font-mono text-[9px] text-zinc-600 uppercase tracking-widest">
            Drag to rotate monitor · Click region to assess
          </div>
        </div>

        {/* Input Side */}
        <div className="lg:col-span-7 space-y-8">
          <AnimatePresence mode="wait">
            {!selectedPart ? (
               <motion.div 
                 key="today"
                 initial={{ opacity: 0 }} animate={{ opacity: 1 }}
                 className="space-y-8 h-full"
               >
                 <div className="flex items-center gap-4">
                   <History size={16} className="text-zinc-500" />
                   <h3 className="font-mono text-[10px] uppercase tracking-[0.4em] text-zinc-500 whitespace-nowrap">Today's Spatial Records</h3>
                   <div className="h-px flex-1 bg-white/5" />
                 </div>

                 <div className="space-y-3">
                   {todayLogs.length === 0 ? (
                     <div className="py-24 border border-dashed border-white/5 rounded-sm flex flex-col items-center justify-center text-center opacity-30">
                        <Dna size={40} className="mb-6" />
                        <span className="font-mono text-[10px] uppercase tracking-widest">Awaiting spatial input transmission...</span>
                     </div>
                   ) : (
                     todayLogs.map((log) => (
                       <div key={log.ts} className="flex items-center justify-between p-4 bg-white/5 border border-white/5 rounded-sm group transition-all hover:border-white/10">
                         <div className="flex items-center gap-5">
                            <div className={cn(
                              "w-8 h-8 rounded-full border flex items-center justify-center",
                              log.intensity >= 7 ? "border-red-500/40 text-red-500" : "border-indigo-500/40 text-indigo-500"
                            )}>
                              <MapPin size={14} />
                            </div>
                            <div>
                               <div className="font-mono text-[11px] uppercase tracking-wider">{log.part}</div>
                               <div className="font-mono text-[9px] uppercase tracking-[0.2em] text-zinc-600 mt-0.5">{log.type} Tension</div>
                            </div>
                         </div>
                         <div className="font-display text-2xl text-white group-hover:text-accent transition-colors">{log.intensity}</div>
                       </div>
                     ))
                   )}
                 </div>
               </motion.div>
            ) : (
              <motion.div 
                key="logging"
                initial={{ opacity: 0, y: 10 }} animate={{ opacity: 1, y: 0 }}
                className="bg-zinc-950 p-10 border border-white/10 rounded-sm space-y-10"
              >
                <div className="flex justify-between items-start">
                   <div className="space-y-1">
                      <div className="font-mono text-[10px] uppercase tracking-[0.3em] text-accent">Internal Logging</div>
                      <h2 className="font-display text-4xl uppercase tracking-tighter">{selectedPart}</h2>
                   </div>
                   <button onClick={() => setSelectedPart(null)} className="text-zinc-600 hover:text-white transition-colors">
                     <History size={18} />
                   </button>
                </div>

                <div className="space-y-10">
                  <div className="space-y-6">
                    <div className="flex justify-between items-end">
                      <label className="font-mono text-[9px] uppercase tracking-widest text-zinc-500">Intensity Gauge</label>
                      <div className="font-display text-2xl text-accent">{intensity}</div>
                    </div>
                    <input 
                      type="range" min="1" max="10" 
                      value={intensity}
                      onChange={(e) => setIntensity(parseInt(e.target.value))}
                      className="w-full accent-accent h-1.5 bg-white/5 appearance-none rounded-full cursor-pointer hover:bg-white/10 transition-colors"
                    />
                    <div className="flex justify-between font-mono text-[8px] uppercase tracking-widest text-zinc-700">
                      <span>Nominal</span>
                      <span>Critical</span>
                    </div>
                  </div>

                  <div className="space-y-4">
                    <label className="font-mono text-[9px] uppercase tracking-widest text-zinc-500">Sensation Type</label>
                    <div className="grid grid-cols-2 gap-4">
                      {['dull', 'sharp'].map((t) => (
                        <button
                          key={t}
                          onClick={() => setType(t as any)}
                          className={cn(
                            "py-4 font-display text-[10px] tracking-[0.2em] uppercase border transition-all",
                            type === t ? "bg-accent/10 border-accent text-accent" : "bg-white/5 border-white/5 text-zinc-500 hover:border-white/10"
                          )}
                        >
                          {t === 'sharp' ? '⚡ Sharp / Nerve' : '🌀 Dull / Muscle'}
                        </button>
                      ))}
                    </div>
                  </div>
                </div>

                <button 
                  onClick={handleLog}
                  disabled={saving}
                  className="w-full py-5 bg-accent text-black font-display text-[11px] font-bold tracking-[0.4em] uppercase hover:bg-white transition-all shadow-[0_40px_100px_rgba(0,242,255,0.15)] group relative overflow-hidden"
                >
                  <span className="relative z-10 flex items-center justify-center gap-2">
                    <Check size={14} /> Commit Entry
                  </span>
                  <div className="absolute inset-0 bg-gradient-to-r from-transparent via-white/20 to-transparent -skew-x-12 translate-x-[-150%] group-hover:translate-x-[150%] transition-transform duration-700" />
                </button>
              </motion.div>
            )}
          </AnimatePresence>
        </div>
      </div>
    </div>
  );
};
